(text "== Ducktop2 MX ULP keyboard daughterboard ==" (at 20.32 12.7 0) (effects (font (size 1.27 1.27))) (uuid 9ca374b6-a67d-4804-9f51-d866ab7d24a9))
(text "65-key compact laptop-style layout, Cherry MX Ultra Low Profile tactile switches, one diode per key." (at 20.32 20.32 0) (effects (font (size 1.27 1.27))) (uuid ee1e47a3-28e1-4918-862c-c2353c3d79e0))
(text "Target physical envelope is about 300 x 80 mm using roughly 18.0-18.5 mm horizontal pitch and 16 mm row pitch." (at 20.32 27.94 0) (effects (font (size 1.27 1.27))) (uuid 00969810-21bb-4008-b20c-35e7ea7c9ff2))
(text "This sheet is the keyboard PCB itself: switches, matrix diodes, EC FFC, and bring-up notes." (at 20.32 35.56 0) (effects (font (size 1.27 1.27))) (uuid 6cedace3-5349-4cac-9c98-608a3729990c))
(text "== 5x14 switch matrix, diode direction locked for EC firmware ==" (at 20.32 55.88 0) (effects (font (size 1.27 1.27))) (uuid 86933aab-491a-4b08-88a6-565b9ee6850a))
(text "Scan assumption: EC drives one column low at a time and reads rows with pull-ups. Each key path is ROW -> diode anode -> diode cathode -> switch -> COL." (at 20.32 63.5 0) (effects (font (size 1.27 1.27))) (uuid 2b93adfe-1ce0-464c-b4ac-e22a69c1bbe7))
