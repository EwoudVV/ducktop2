(text "== Ducktop2 MX ULP keyboard daughterboard ==" (at 20.32 12.7 0) (effects (font (size 1.27 1.27))) (uuid 379e8de9-2761-5681-93e7-0c81483e60cc))
(text "65-key compact laptop-style layout, Cherry MX Ultra Low Profile tactile switches, one diode per key." (at 20.32 20.32 0) (effects (font (size 1.27 1.27))) (uuid 10f001d2-6c56-52f4-ab95-20d362e8e5b4))
(text "Target physical envelope is about 300 x 80 mm using roughly 18.0-18.5 mm horizontal pitch and 16 mm row pitch." (at 20.32 27.94 0) (effects (font (size 1.27 1.27))) (uuid 33f32eaf-6758-50ac-a69e-94fa8ef3a2fa))
(text "This sheet is the keyboard PCB itself: switches, matrix diodes, EC FFC, and bring-up notes." (at 20.32 35.56 0) (effects (font (size 1.27 1.27))) (uuid e5cbfb5a-9b1f-576f-8ad1-dee956ba20a3))
(text "== 5x14 switch matrix, diode direction locked for EC firmware ==" (at 20.32 55.88 0) (effects (font (size 1.27 1.27))) (uuid 85f0066d-7001-5086-a996-e88248a631a1))
(text "Scan assumption: EC drives one column low at a time and reads rows with pull-ups. Each key path is ROW -> diode anode -> diode cathode -> switch -> COL." (at 20.32 63.5 0) (effects (font (size 1.27 1.27))) (uuid 5b8b2ebd-d2c1-5599-8580-eb3489fcc29f))
