(text "== Native PCIe Gigabit Ethernet on LattePanda Mu default HSIO6 ==" (at 20.32 12.7 0) (effects (font (size 1.27 1.27))) (uuid f099f1c8-50a2-57e9-b085-2261176d13a2))
