(text "NOTES:" (at 20.32 330.2 0) (effects (font (size 1.27 1.27))) (uuid 16799f1d-3ea2-422a-ad05-60b8939072ae))
(text "Mu VIN is tied directly to VSYS; no intermediate module VIN buck." (at 20.32 337.82 0) (effects (font (size 1.27 1.27))) (uuid 1948a1f2-c3c0-4e53-8fa9-fbaddd60230a))
(text "HSIO0 + USB2_P2 feed VL822 upstream; HSIO1 + USB2_P1 feed the M.2 E-key radio slot." (at 20.32 345.44 0) (effects (font (size 1.27 1.27))) (uuid b51d1991-5878-4998-9cb1-892066ff2622))
(text "DDIB HDMI 2.0 nets leave to sheet 11 for the retained Intehill monitor/controller path." (at 20.32 354.33 0) (effects (font (size 1.27 1.27))) (uuid e31fafe5-675b-42e7-a8f9-ee616f468f6c))
(text "TCP0 HDMI 2.0 lane/HPD/DDC nets leave to sheet 6 for the external HDMI-A output." (at 20.32 361.95 0) (effects (font (size 1.27 1.27))) (uuid 7b309ee5-ed34-482a-b4a2-872fb5502aaf))
(text "USB2_P3 is EC; USB2_P4 is touch; USB2_P5 is radio audio; USB2_P7 is maker MCU USB; USB2_P8 is trackpad." (at 20.32 369.57 0) (effects (font (size 1.27 1.27))) (uuid 40560fbf-31e7-44e3-bd60-e9cd5c050fb5))
(text "VL822 downstream PE/OC/data leave this sheet; USB-C VBUS/CC/muxing lives on sheet 4." (at 20.32 378.46 0) (effects (font (size 1.27 1.27))) (uuid 1bad6ce7-5a32-4cea-b908-4698a0abee31))
(text "SYS_5V/SYS_3V3 use 0.6V FB dividers: 732k/100k and 450k/100k; verify compensation before fab." (at 20.32 386.08 0) (effects (font (size 1.27 1.27))) (uuid 90345ea6-67dd-4131-950d-1eb8249ddce4))
(text "TPS7A0210 is a real 1.0V part, but sits at the low edge of the VL822 1.0-1.1V rail range." (at 20.32 393.7 0) (effects (font (size 1.27 1.27))) (uuid 85857fa4-3c76-4fb8-b784-1ba26135007b))
(text "M.2 M-key is wired as PCIe x1. CLKREQM is intentionally left NC per DFRobot reference mining." (at 20.32 401.32 0) (effects (font (size 1.27 1.27))) (uuid 64c7445e-5566-4ac3-92b6-700fa3da5c65))
(text "USB2_P6 is reserved for the Mu Type-C PD controller direction; trackpad consumes the former USB2_P8 spare." (at 20.32 408.94 0) (effects (font (size 1.27 1.27))) (uuid f6bc555d-e02a-4930-97b1-9cc59ca6a59d))
