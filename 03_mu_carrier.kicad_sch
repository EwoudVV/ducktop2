(text "NOTES:" (at 20.32 330.2 0) (effects (font (size 1.27 1.27))) (uuid efdfb553-d201-56c1-a8eb-d27020b14e07))
(text "Mu VIN is tied directly to VSYS; no intermediate module VIN buck." (at 20.32 337.82 0) (effects (font (size 1.27 1.27))) (uuid 2fa33392-3f4b-5a1a-8310-72aff34b666b))
(text "HSIO0 + USB2_P2 feed VL822 upstream; HSIO1 + USB2_P1 feed the M.2 E-key radio slot." (at 20.32 345.44 0) (effects (font (size 1.27 1.27))) (uuid e75ff9ad-583a-5101-ba5c-318614533281))
(text "DDIB HDMI 2.0 nets leave to sheet 11 for the retained Intehill monitor/controller path." (at 20.32 354.33 0) (effects (font (size 1.27 1.27))) (uuid a6e74751-7e08-55ab-8253-a65b3b1a53ce))
(text "TCP0 HDMI 2.0 lane/HPD/DDC nets leave to sheet 6 for the external HDMI-A output." (at 20.32 361.95 0) (effects (font (size 1.27 1.27))) (uuid dc847778-4b12-5153-80fe-cc3c9ec2f9ba))
(text "USB2_P3 is EC; USB2_P4 is touch; USB2_P5 is radio audio; USB2_P7 is maker MCU USB; USB2_P8 is trackpad." (at 20.32 369.57 0) (effects (font (size 1.27 1.27))) (uuid dc4b0a88-31ed-5377-91e1-8654c185b858))
(text "VL822 downstream PE/OC/data leave this sheet; USB-C VBUS/CC/muxing lives on sheet 4." (at 20.32 378.46 0) (effects (font (size 1.27 1.27))) (uuid b36cb32b-4578-52be-98c4-8402843802c3))
(text "SYS_5V/SYS_3V3 use 0.6V FB dividers: 732k/100k and 450k/100k; verify compensation before fab." (at 20.32 386.08 0) (effects (font (size 1.27 1.27))) (uuid e917ea7d-8951-573f-a7fb-b11b62f6660a))
(text "TPS7A0210 is a real 1.0V part, but sits at the low edge of the VL822 1.0-1.1V rail range." (at 20.32 393.7 0) (effects (font (size 1.27 1.27))) (uuid 794cd190-a142-5ca9-a42c-b6c1c00d9dd9))
(text "M.2 M-key is wired as PCIe x1. CLKREQM is intentionally left NC per DFRobot reference mining." (at 20.32 401.32 0) (effects (font (size 1.27 1.27))) (uuid ceb9d42b-70f9-54b4-b84c-4e9eb0b6991c))
(text "USB2_P6 is reserved for the Mu Type-C PD controller direction; trackpad consumes the former USB2_P8 spare." (at 20.32 408.94 0) (effects (font (size 1.27 1.27))) (uuid 13ca177d-0f28-5f00-9b8f-6a1588cf256e))
