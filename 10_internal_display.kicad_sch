(text "NOTES:" (at 20.32 309.88 0) (effects (font (size 1.27 1.27))) (uuid 18713d3e-3c20-45a1-9a86-0f7e11460ec6))
(text "J80 high-speed pins follow the Mu eDP source connector; power/backlight pins are not pass-through to avoid backfeed." (at 20.32 317.5 0) (effects (font (size 1.27 1.27))) (uuid 289fa4c5-7a9f-4873-83ad-d1e55a7c652b))
(text "J81 follows the 40-pin eDP pinout in gen/Pinouts_README.md: lanes 3..0, AUX, HPD, LCD_3V3, BL_PWR, BL_EN/PWM." (at 20.32 325.12 0) (effects (font (size 1.27 1.27))) (uuid 94693cf6-989f-46a5-b3b8-f280031a3a46))
(text "J82 provides the reference I2C touch pinout; keep the separate USB touch header if the reused 16in panel uses USB touch." (at 20.32 332.74 0) (effects (font (size 1.27 1.27))) (uuid 3489e8fd-7e15-49aa-b4bf-c84ce4113764))
(text "Exact J80/J81 mechanical footprints and cable orientation still need the real panel/controller hardware on the bench." (at 20.32 340.36 0) (effects (font (size 1.27 1.27))) (uuid f5e12f15-885e-4260-83e6-c44082effee7))
