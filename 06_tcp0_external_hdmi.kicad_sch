(text "NOTES:" (at 20.32 220.98 0) (effects (font (size 1.27 1.27))) (uuid 8e867282-3e2d-557b-882d-36eca8883cac))
(text "J30 is the outside-world HDMI jack; sheet 11 J300 remains only the internal Intehill HDMI plug." (at 20.32 228.6 0) (effects (font (size 1.27 1.27))) (uuid 05f9840e-8e5c-58f4-845e-de50b07796fb))
(text "CEC is ESD-protected but not connected to the Mu or EC in this pass." (at 20.32 236.22 0) (effects (font (size 1.27 1.27))) (uuid 3e3ffd0b-478e-59c7-94b9-be3bdd09284e))
(text "Pre-layout must verify TCP0 HDMI lane order/polarity against the selected Mu BIOS/reference design." (at 20.32 243.84 0) (effects (font (size 1.27 1.27))) (uuid f3200669-f29f-5752-85a2-2eafc4f02e90))
(text "Treat this as HDMI 2.0/18Gbps capable: short routing, low-cap ESD, solid return path, no HDMI 1.4-only parts." (at 20.32 251.46 0) (effects (font (size 1.27 1.27))) (uuid ba2f0499-5969-55b7-b9ad-5cdf829a817b))
(text "TCP1 remains the better future candidate for a Type-C video/PD port if a later BIOS/display plan needs it." (at 20.32 259.08 0) (effects (font (size 1.27 1.27))) (uuid df9e5d9b-4de5-5c3a-94a3-00d2ece0a0f2))
