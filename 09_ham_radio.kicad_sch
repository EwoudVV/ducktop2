(text "NOTES:" (at 20.32 205.74 0) (effects (font (size 1.27 1.27))) (uuid a82c12aa-da60-5139-b3af-4414d7887cff))
(text "DRA818V/U pinout is locked to Dorji V1.23: pin16 RXD<-EC_TX, pin17 TXD->EC_RX, pin12 RF 50 ohm." (at 20.32 213.36 0) (effects (font (size 1.27 1.27))) (uuid 2da86846-ef1f-5e4e-ab0e-4312f20b589c))
(text "LPF values are 5th-order Butterworth starting points; simulate/bench-check harmonics for Part 97 before fab." (at 20.32 220.98 0) (effects (font (size 1.27 1.27))) (uuid cb78bddb-9530-53fa-aa19-130961bc184b))
(text "BGS12 control low selects RF1/pin3 internal feed; high selects RF2/pin1 rear external feed." (at 20.32 228.6 0) (effects (font (size 1.27 1.27))) (uuid 9b446014-0046-5d3b-bf17-c824e1a6843b))
(text "Default RF switch state selects the internal/PCB antenna feed; rear external SMA/u.FL is the high-performance option." (at 20.32 236.22 0) (effects (font (size 1.27 1.27))) (uuid cbc5fb76-def8-57d8-b49b-8e2e4049e2d1))
(text "A true 2m PCB antenna is laptop-scale-impractical; use a loaded internal/enclosure antenna feed or rear external whip." (at 20.32 243.84 0) (effects (font (size 1.27 1.27))) (uuid 46237b34-349d-54df-9b8f-1f0f87813f6b))
(text "Use board-edge keepouts around rear external SMA paths; internal antennas need separation from GPS and Wi-Fi antennas." (at 20.32 251.46 0) (effects (font (size 1.27 1.27))) (uuid bb1933aa-51bf-54f7-8cde-e1534921d5b6))
(text "GPS APRS support is software/audio-path work using the MAX-M10S sheet and the VHF radio path." (at 20.32 259.08 0) (effects (font (size 1.27 1.27))) (uuid edd9da4a-913f-520b-9e85-52c5a567e178))
(text "RF switch truth table, RF layout, and filter parasitics remain RF-review items; DRA818 module pinout is set." (at 20.32 266.7 0) (effects (font (size 1.27 1.27))) (uuid 7d8dc10d-244e-5a37-b87c-c454d6712e5a))
