(text "NOTES:" (at 20.32 205.74 0) (effects (font (size 1.27 1.27))) (uuid 401d9463-c8ad-4b9c-8003-e090ff1c5e1b))
(text "DRA818V/U pinout is locked to Dorji V1.23: pin16 RXD<-EC_TX, pin17 TXD->EC_RX, pin12 RF 50 ohm." (at 20.32 213.36 0) (effects (font (size 1.27 1.27))) (uuid 6c42f7f3-75b2-4a72-a17a-fe4b55b79b15))
(text "LPF values are 5th-order Butterworth starting points; simulate/bench-check harmonics for Part 97 before fab." (at 20.32 220.98 0) (effects (font (size 1.27 1.27))) (uuid e52433e3-9f6d-435b-9e0a-3750477e4501))
(text "BGS12 control low selects RF1/pin3 internal feed; high selects RF2/pin1 rear external feed." (at 20.32 228.6 0) (effects (font (size 1.27 1.27))) (uuid a0b3ac71-cb7f-4d82-8fe2-6fa041ffcd5a))
(text "Default RF switch state selects the internal/PCB antenna feed; rear external SMA/u.FL is the high-performance option." (at 20.32 236.22 0) (effects (font (size 1.27 1.27))) (uuid 529f24e1-0aee-4300-bd72-830a4f6f2ff9))
(text "A true 2m PCB antenna is laptop-scale-impractical; use a loaded internal/enclosure antenna feed or rear external whip." (at 20.32 243.84 0) (effects (font (size 1.27 1.27))) (uuid 716d211e-c828-442c-a412-97d9b45d8bc6))
(text "Use board-edge keepouts around rear external SMA paths; internal antennas need separation from GPS and Wi-Fi antennas." (at 20.32 251.46 0) (effects (font (size 1.27 1.27))) (uuid 447ef363-2909-40aa-aed9-d0cfc61d29d4))
(text "GPS APRS support is software/audio-path work using the MAX-M10S sheet and the VHF radio path." (at 20.32 259.08 0) (effects (font (size 1.27 1.27))) (uuid b1007925-3243-4061-8417-ad66846ce837))
(text "RF switch truth table, RF layout, and filter parasitics remain RF-review items; DRA818 module pinout is set." (at 20.32 266.7 0) (effects (font (size 1.27 1.27))) (uuid ec305ede-fd6f-403c-b4a8-8bb30d7d9026))
