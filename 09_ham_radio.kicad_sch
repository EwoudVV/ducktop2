(text "NOTES:" (at 20.32 205.74 0) (effects (font (size 1.27 1.27))) (uuid af1e2a56-6f19-500d-95c3-9c78f04ad71b))
(text "Dorji pinout: pins 9/10 GND; pins 2/4/11/13/14/15 NC; pin12 ANT 50 ohm; pin16 RXD; pin17 TXD." (at 20.32 213.36 0) (effects (font (size 1.27 1.27))) (uuid 149a00e6-ea1e-538a-82ca-39956efb43c5))
(text "H/L is never driven high: fitted 0R selects low power; omitted 0R floats for high power only after RF release." (at 20.32 220.98 0) (effects (font (size 1.27 1.27))) (uuid 77c0d0de-b064-576e-be76-1a5222d9d8b9))
(text "FL240 LFCN-160+ (8W at 25C) and FL250 ULP-470+ (2W) are fitted LPFs; calculate both 50-ohm launches from the final stackup." (at 20.32 228.6 0) (effects (font (size 1.27 1.27))) (uuid 80517f68-d88c-56de-a7ab-973641ed1b00))
(text "PE42820 is rated 43dBm CW through 2GHz when powered; RADIO_4V0 powers switch and module together." (at 20.32 236.22 0) (effects (font (size 1.27 1.27))) (uuid 53e9330b-a94c-5bd0-8ad2-a21af54dd3b0))
(text "A true 2m PCB antenna is laptop-scale-impractical; use a loaded internal/enclosure antenna feed or rear external whip." (at 20.32 243.84 0) (effects (font (size 1.27 1.27))) (uuid b86b6f68-1f17-53ba-b7a9-16a1c6ac50df))
(text "Validate antenna match/VSWR, enclosure detuning, duty cycle, harmonics, and GNSS/Wi-Fi isolation before RF release." (at 20.32 251.46 0) (effects (font (size 1.27 1.27))) (uuid 23bde577-d956-51a1-a885-d91ee00fee8c))
(text "GPS APRS support is software/audio-path work using the MAX-M10S sheet and the VHF radio path." (at 20.32 259.08 0) (effects (font (size 1.27 1.27))) (uuid e73fd427-a3ef-5418-99dc-53da7a6bc169))
(text "U260/U261 force both radios out of TX for simultaneous requests; U241/U251 freeze antenna selection for the full transmit interval." (at 20.32 266.7 0) (effects (font (size 1.27 1.27))) (uuid a1bd9357-9295-5f40-a069-0ccecc1a9ddf))
(text "R229/R231 select 0.5W prototype power. Filter ratings do not prove emissions compliance; verify both outputs on a spectrum analyzer." (at 20.32 274.32 0) (effects (font (size 1.27 1.27))) (uuid fabbb285-bec8-5c08-ba90-2dc7ec95d51b))
(text "R225/R226 set safe EC defaults; radio-powered Ioff buffers prevent injection into unpowered DRA818 inputs." (at 20.32 281.94 0) (effects (font (size 1.27 1.27))) (uuid 6d8a24e0-2e00-5186-ae8a-7ffa2e93f5b9))
