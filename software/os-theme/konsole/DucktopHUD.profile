[Appearance]
AntiAliasFonts=true
BoldIntense=true
ColorScheme=DucktopHUD
Font=JetBrains Mono,11,-1,5,50,0,0,0,0,0
LineSpacing=0

[Cursor Options]
CursorShape=1

[General]
LocalTabTitleFormat=%d : %n
Name=DucktopHUD
Parent=FALLBACK/
RemoteTabTitleFormat=%h : %u

[Interaction Options]
CopyTextAsHTML=false
TrimLeadingSpacesInSelectedText=true
TrimTrailingSpacesInSelectedText=true

[Scrolling]
HistoryMode=2
HistorySize=10000

[Terminal Features]
BlinkingCursorEnabled=true
