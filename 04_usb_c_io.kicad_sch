(text "TPS25810 handles DFP CC/VBUS; TI rates the HD3SS6126 high-bandwidth path up to 10Gbps." (at 20.32 20.32 0) (effects (font (size 1.27 1.27))) (uuid bedb99a8-47e5-5bd4-8451-599ebb668010))
(text "CHG/CHG_HI are strapped low for default USB current; branch-switch and port FAULT outputs share Mu USB_OC#." (at 20.32 27.94 0) (effects (font (size 1.27 1.27))) (uuid 1c0d3f06-4532-5a16-b766-60ad07244878))
(text "Both ports use MU_HOST_ACTIVE = PSON AND MU_12V_PG; suspend or a failed Mu rail removes VBUS." (at 20.32 35.56 0) (effects (font (size 1.27 1.27))) (uuid 0fbda446-4174-5fac-ad19-66d85a7016a8))
(text "SYS_5V BUDGET HOLD: default-current ports still share one rail with trackpad, fan, audio, radios, and maker power; simultaneous-load validation/load shedding is mandatory." (at 20.32 43.18 0) (effects (font (size 1.27 1.27))) (uuid 4b5ed32b-6566-5928-9c9b-0c93df98bb21))
(text "== J11 native Mu USB 3.2 Gen 2 Type-C host port 1 ==" (at 20.32 58.42 0) (effects (font (size 1.27 1.27))) (uuid c94f6a52-a1a6-501f-9c77-a1c94d68dcc2))
