(text "== USB-C power inputs: three CH224K PD sink triggers ==" (at 20.32 12.7 0) (effects (font (size 1.27 1.27))) (uuid 040887f6-b47b-4f90-b407-a8c1c4ccd840))
(text "Each CH224K uses resistor mode: CFG1=56k to GND requests 15V; CFG2/CFG3 are NC." (at 20.32 20.32 0) (effects (font (size 1.27 1.27))) (uuid 31b99325-b25f-4c42-af10-4a1ecd6c1594))
(text "CH224K performs USB-C PD negotiation; BQ25798 on sheet 1 is the buck-boost charger / NVDC power path." (at 20.32 27.94 0) (effects (font (size 1.27 1.27))) (uuid cd847ed8-c330-4433-8ec9-3a35930992d1))
(text "Only J21 carries USB2 D+/D- to BQ25798; J22/J23 are power-only charge inputs." (at 20.32 35.56 0) (effects (font (size 1.27 1.27))) (uuid 00677513-1347-443a-ae8e-405f7bad67ff))
(text "== J21 USB-C PD sink input 1: CH224K requests 15V ==" (at 20.32 50.8 0) (effects (font (size 1.27 1.27))) (uuid f8bc4260-6ed9-4810-a60e-9bafeec839cb))
