(text "NOTES:" (at 20.32 640.08 0) (effects (font (size 1.27 1.27))) (uuid 29558797-eadc-58cb-8891-ada8ff207898))
(text "Eight DF40 contacts share RADIO_DB_5V and thirty contacts are ground; route them as short, wide pours with stitching vias." (at 20.32 647.7 0) (effects (font (size 1.27 1.27))) (uuid e0c60fe0-acb7-5c8d-a15a-cc3da6fa9e22))
(text "J2300 pin 44 is passively grounded only on the daughterboard. High means absent; low means physically installed." (at 20.32 655.32 0) (effects (font (size 1.27 1.27))) (uuid 485c895b-884b-5b54-a4bd-4dc8fdfed77e))
(text "The system-audio hub keeps its own codec on port 2; optional radio codec port 1 may remain empty without blocking enumeration." (at 20.32 662.94 0) (effects (font (size 1.27 1.27))) (uuid 24e5afa9-bc25-5f0a-8933-560c56dd01eb))
(text "USB data and VBUS remain physically disconnected until RADIO_DB_PG is valid; daughterboard faults cannot back-power the mainboard." (at 20.32 670.56 0) (effects (font (size 1.27 1.27))) (uuid e29e7dc0-4479-5780-8334-f05d0b93791d))
(text "Firmware must require PRESENT_N low and FAULT_N high before asserting PWR_EN, then require PG high within a timeout." (at 20.32 678.18 0) (effects (font (size 1.27 1.27))) (uuid 1dce51ff-ba9f-517b-85fc-b599e5eb0af7))
(text "R2340-R2356 limit fault current on every removable-board GPIO/UART/control line; no signal pin directly crosses J2300." (at 20.32 685.8 0) (effects (font (size 1.27 1.27))) (uuid 857487e2-1928-5e0e-baa5-92efaf475c6f))
