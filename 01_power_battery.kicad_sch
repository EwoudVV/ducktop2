(text "D5-D7/D191: K(pin1)=VBUS_COMBINED, A(pin2)=input raw/fused VBUS" (at 379.73 20.32 0) (effects (font (size 1.27 1.27))) (uuid 88d69288-4434-40d7-a070-bf715c38f6a5))
(text "J190 is the single AUX/SOLAR physical input; USB-C PD negotiation remains only on sheet 5." (at 379.73 25.4 0) (effects (font (size 1.27 1.27))) (uuid 9c880bd1-80a5-4514-9aaa-5101caf252e3))
(text "AUX divider maps 24V to about 2.56V and 30V abs-max to about 3.19V at the EC ADC." (at 379.73 31.75 0) (effects (font (size 1.27 1.27))) (uuid fb280914-a83b-4267-ba75-28c38c1a8309))
(text "Default build populates D191 for random DC; solar option feeds U3 from same terminal via D8." (at 379.73 38.1 0) (effects (font (size 1.27 1.27))) (uuid c211d7cf-3da7-4648-a63c-62b7762b7dcd))
(text "Do not populate D8 and D191 together unless dual-charger input policy is intentionally reviewed." (at 379.73 44.45 0) (effects (font (size 1.27 1.27))) (uuid 88ed6899-1569-4b3a-9724-311f2105bc81))
(text "== U3 bq24650 optional solar MPPT from shared AUX/SOLAR input ==" (at 459.74 20.32 0) (effects (font (size 1.27 1.27))) (uuid f38fd169-4843-4210-bce4-8709211aa262))
