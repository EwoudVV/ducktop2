(text "D5-D7/D191: K(pin1)=VBUS_COMBINED, A(pin2)=input raw/fused VBUS" (at 379.73 20.32 0) (effects (font (size 1.27 1.27))) (uuid 529d2275-750d-53fd-96b9-967494be8124))
(text "J190 is the single AUX/SOLAR physical input; USB-C PD negotiation remains only on sheet 5." (at 379.73 25.4 0) (effects (font (size 1.27 1.27))) (uuid 4d212fdf-c5bd-5ee6-a933-90593b59a3eb))
(text "AUX divider maps 24V to about 2.56V and 30V abs-max to about 3.19V at the EC ADC." (at 379.73 31.75 0) (effects (font (size 1.27 1.27))) (uuid b5aa367e-00cc-5a5b-92da-74535915dc6f))
(text "Default build populates D191 for random DC; solar option feeds U3 from same terminal via D8." (at 379.73 38.1 0) (effects (font (size 1.27 1.27))) (uuid 98544216-0654-5408-99ff-6fb6281d87a0))
(text "Do not populate D8 and D191 together unless dual-charger input policy is intentionally reviewed." (at 379.73 44.45 0) (effects (font (size 1.27 1.27))) (uuid 361f6799-f130-53a9-9ac9-1b3965be83a5))
(text "== U3 bq24650 optional solar MPPT from shared AUX/SOLAR input ==" (at 459.74 20.32 0) (effects (font (size 1.27 1.27))) (uuid 783b5a5e-3153-5988-9b60-55da38439786))
